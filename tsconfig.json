{
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    /* type checking */
    "strict": true,
    /* modules */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    /* interop constraints 
    "esModuleInterop": true,*/
    "forceConsistentCasingInFileNames": true, 
    "isolatedModules": true,
    /* emit */
    "declaration": true,
    "declarationDir": "./dist/types", //
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": true //
  }
}

